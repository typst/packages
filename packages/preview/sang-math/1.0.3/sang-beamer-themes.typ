// Hàm lấy theme theo số nguyên (1 đến 30) hoặc chuỗi ("1" đến "30")
// Nếu không tìm thấy, trả về theme 1 (Navy Gold)
#let get-beamer-theme(id) = {
  let key = str(id)
  if key in beamer-themes {
    return beamer-themes.at(key)
  } else {
    return beamer-themes.at("1")
  }
}
