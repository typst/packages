{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "brilliant-cv Metadata Schema",
  "type": "object",
  "properties": {
    "header_quote": {
      "type": "string",
      "description": "Italic tagline displayed below your name and contact info."
    },
    "cv_footer": {
      "type": "string",
      "description": "Text shown in the left side of the footer on CV pages."
    },
    "letter_footer": {
      "type": "string",
      "description": "Text shown in the left side of the footer on cover letter pages."
    },
    "layout": {
      "type": "object",
      "properties": {
        "awesome_color": {
          "type": "string",
          "description": "Optional values: skyblue, red, nephritis, concrete, darknight. You can also use a custom color by hex code i.e. '#1E90FF'",
          "pattern": "^(skyblue|red|nephritis|concrete|darknight|#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3}))$"
        },
        "before_section_skip": {
          "type": "string",
          "description": "Spacing before sections",
          "pattern": "^\\d*\\.?\\d+([eE][+-]?\\d+)?(pt|mm|cm|in|em)$"
        },
        "before_entry_skip": {
          "type": "string",
          "description": "Spacing before entries",
          "pattern": "^\\d*\\.?\\d+([eE][+-]?\\d+)?(pt|mm|cm|in|em)$"
        },
        "before_entry_description_skip": {
          "type": "string",
          "description": "Spacing before entry descriptions",
          "pattern": "^\\d*\\.?\\d+([eE][+-]?\\d+)?(pt|mm|cm|in|em)$"
        },
        "paper_size": {
          "type": "string",
          "description": "Sets paper size and standard margins, Optional values: us-letter. Default is a4.",
          "pattern": "^(a4|us-letter|#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3}))$"
        },
        "date_width": {
          "type": "string",
          "description": "Width of the right column of a cvEntry",
          "pattern": "^\\d*\\.?\\d+([eE][+-]?\\d+)?(pt|mm|cm|in|em)$"
        },
        "fonts": {
          "type": "object",
          "properties": {
            "regular_fonts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "header_font": {
              "type": "string"
            }
          }
        },
        "header": {
          "type": "object",
          "properties": {
            "header_align": {
              "type": "string",
              "description": "Optional values: left, center, right",
              "enum": [
                "left",
                "center",
                "right"
              ]
            },
            "display_profile_photo": {
              "type": "boolean",
              "description": "Display profile photo or not"
            },
            "profile_photo_radius": {
              "type": "string",
              "description": "Radius in % to clip profile photo at. Default: 50%",
              "pattern": "(?:0|[1-9]\\d*)%"
            },
            "info_font_size": {
              "type": "string",
              "description": "Font size for personal info",
              "pattern": "^\\d*\\.?\\d+([eE][+-]?\\d+)?(pt|mm|cm|in|em)$"
            }
          },
          "required": [
            "header_align",
            "display_profile_photo"
          ]
        },
        "entry": {
          "type": "object",
          "properties": {
            "display_entry_society_first": {
              "type": "boolean",
              "description": "Display company in bold or position in bold"
            },
            "display_logo": {
              "type": "boolean",
              "description": "Display organisation logo or not"
            }
          },
          "required": [
            "display_entry_society_first",
            "display_logo"
          ]
        },
        "footer": {
          "type": "object",
          "properties": {
            "display_footer": {
              "type": "boolean",
              "description": "Display footer or not"
            },
            "display_page_counter": {
              "type": "boolean",
              "description": "Display page counter in footer or not"
            }
          },
          "required": [
            "display_page_counter"
          ]
        },
        "section": {
          "type": "object",
          "description": "Controls the visual treatment of section titles.",
          "properties": {
            "title_highlight": {
              "type": "string",
              "enum": ["first-letters", "full", "none"],
              "description": "How section titles are highlighted: 'first-letters' (default, Latin convention) renders the first N characters in accent color; 'full' renders the entire title in accent color (CJK convention); 'none' renders the entire title in black."
            },
            "title_highlight_letters": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of leading characters rendered in accent color when title_highlight = 'first-letters'. Ignored for the other modes. Defaults to 3."
            }
          }
        }
      },
      "required": [
        "awesome_color",
        "before_section_skip",
        "before_entry_skip",
        "before_entry_description_skip",
        "header",
        "entry",
        "footer"
      ]
    },
    "inject": {
      "type": "object",
      "properties": {
        "custom_ai_prompt_text": {
          "type": "string",
          "description": "Custom AI prompt text. If defined, it will be injected into the CV."
        },
        "injected_keywords_list": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keywords to inject into the CV. If defined, they will be injected."
        }
      },
      "required": []
    },
    "personal": {
      "type": "object",
      "properties": {
        "first_name": {
          "type": "string"
        },
        "last_name": {
          "type": "string"
        },
        "display_name": {
          "type": "string",
          "description": "Optional. Overrides the Latin 'first (light) + last (bold)' header treatment with a single styled string. Use for CJK profiles or any profile where the split feels wrong."
        },
        "address": {
          "type": "string",
          "description": "Optional. Mailing address used as the default sender-address in the cover letter."
        },
        "info": {
          "type": "object",
          "properties": {
            "github": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "linkedin": {
              "type": "string"
            },
            "gitlab": {
              "type": "string"
            },
            "homepage": {
              "type": "string"
            },
            "orcid": {
              "type": "string"
            },
            "researchgate": {
              "type": "string"
            },
            "extraInfo": {
              "type": "string"
            },
            "custom": {
              "type": "object",
              "patternProperties": {
                "^custom-[a-z0-9-]+$": {
                  "type": "object",
                  "properties": {
                    "awesomeIcon": {
                      "type": "string"
                    },
                    "text": {
                      "type": "string"
                    },
                    "link": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "awesomeIcon",
                    "text"
                  ]
                }
              },
              "additionalProperties": false
            }
          }
        }
      },
      "required": [
        "first_name",
        "last_name",
        "info"
      ]
    }
  },
  "required": []
}